# Dependencies
node_modules/

# TypeScript build intermediates
*.tsbuildinfo

# NOTE: bettercallclaude/mcp-servers/*/dist/ is NOT ignored — compiled bundles
# for the bundled local STDIO server (ollama) are checked into git so end
# users don't need a build step. All HTTP MCPs now live in the separate
# BetterCallClaudeMCP repo and are reached via URLs in .mcp.json.

# Runtime data (SQLite databases created at runtime)
bettercallclaude/mcp-servers/*/data/

# Package outputs
dist/mcpb/
dist/mcpb-staging/
dist/*.zip

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Environment and secrets
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp

# Project instructions (local only)
CLAUDE.md

# Python (for development tooling)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Test coverage
coverage/

# Development artifacts
claudedocs/
.serena/

# Python linter cache
.ruff_cache/

# Generated installation metadata
manifest.json
version.txt
AGENTS.md

# Skill development & evaluation artifacts (not part of the shipped plugin)
legal-briefing-review-*.html
legal-briefing-trigger-eval-review.html
bettercallclaude/skills/*-workspace/
